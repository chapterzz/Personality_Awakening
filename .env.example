# API (NestJS)
PORT=3001

# Database (T1.2+ / T1.3 docker-compose `db`)
# 与 `prisma/schema.prisma` 一致；本地开发可复制到仓库根 `.env`，或按需覆盖 `prisma/.env`（仓库内已提供占位 URL 供 `pnpm db:validate`）。
# 与 `docker-compose.yml` 默认账号一致时可使用：
# DATABASE_URL="postgresql://ppa:ppa@localhost:5432/ppa?schema=public"

# Redis（T1.3 docker-compose `redis`；后续 WS/限流等使用）
# REDIS_URL="redis://localhost:6379"

# Docker Compose 主机端口（可选；与本机已有服务冲突时修改）
# PPA_POSTGRES_PORT=5432
# PPA_REDIS_PORT=6379
