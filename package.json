{
  "name": "personality-planet-awakening",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "prepare": "node scripts/prepare-husky.cjs",
    "dev:web": "pnpm --filter web dev",
    "dev:api": "pnpm --filter api start:dev",
    "build": "pnpm -r run build",
    "lint": "pnpm -r run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "gate:static": "pnpm run build && pnpm run lint && pnpm run format:check",
    "test": "pnpm --filter api test",
    "test:unit": "pnpm test && pnpm --filter web run test:unit",
    "test:integration": "pnpm --filter api run test:e2e",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium",
    "test:gate": "pnpm run gate:static && pnpm run test:unit && pnpm run test:integration",
    "db:generate": "prisma generate",
    "db:validate": "prisma validate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "prettier": "^3.5.3",
    "prisma": "^6.8.2"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md,yml,yaml}": "prettier --write"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@scarf/scarf",
      "unrs-resolver"
    ]
  },
  "dependencies": {
    "@prisma/client": "6.19.3"
  }
}
